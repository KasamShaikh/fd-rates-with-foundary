# Build context lives at the repo root so the Dockerfile can `COPY backend/`.
# These paths are relative to the repo root.

# Local-only artifacts and secrets
.env
.env.template
.git
.gitignore
.github
.vscode

# infra not needed in backend image
infra/

# [SPA-SERVE-FROM-BACKEND] Frontend source excluded, but build output is kept
# so the Dockerfile can copy frontend/build into the image and serve the SPA
# from Flask. To revert, replace the two lines below with: frontend/
frontend/node_modules/
frontend/src/
frontend/public/
frontend/package.json
frontend/package-lock.json
frontend/.env.development

# Backend local caches and dev outputs
backend/_local_results/
backend/local.settings.json
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/.pytest_cache/

# Docs & scripts not needed at runtime
README.md
setup.ps1
*.md
