    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2023-12-01",
      "name": "[variables('swaName')]",
      "location": "[parameters('swaLocation')]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      },
      "properties": {
