{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "5491608027828321205"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "defaultValue": "fdrates",
      "metadata": {
        "description": "Base name for all resources"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "centralindia",
      "metadata": {
        "description": "Azure region for deployment"
      }
    },
    "aiLocation": {
      "type": "string",
      "defaultValue": "swedencentral",
      "metadata": {
        "description": "AI Foundry / Cognitive Services region"
      }
    },
    "allowedOrigin": {
      "type": "string",
      "defaultValue": "http://localhost:3000",
      "metadata": {
        "description": "Origin allowed by the backend CORS policy. Set to the deployed Static Web App URL once known."
      }
    },
    "backendImageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Container image tag for the backend. Override per deployment (e.g. git SHA)."
      }
    },
    "bootstrapImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/k8se/quickstart:latest",
      "metadata": {
        "description": "Placeholder image used while ACR is empty (first-time bootstrap)."
      }
    },
    "useAcrImage": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Set true once the backend image has been pushed to ACR. Switches the Container App from the bootstrap image to <acr>/fdrates-backend:<tag>."
      }
    },
    "swaLocation": {
      "type": "string",
      "defaultValue": "eastasia",
      "metadata": {
        "description": "Region for the Static Web App (Free SKU is not available in every region)."
      }
    },
    "allowedClientIpAddresses": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Client IPs allowed to access the storage account data plane. Empty = allow all."
      }
    },
    "deployAppService": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Also deploy backend on an App Service Plan (Linux Web App for Containers) alongside Container Apps."
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "B1",
      "metadata": {
        "description": "App Service Plan SKU when deployAppService=true (e.g. B1, B2, P0v3, P1v3)."
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[uniqueString(resourceGroup().id)]",
    "storageAccountName": "[toLower(format('{0}st{1}', parameters('baseName'), variables('uniqueSuffix')))]",
    "acrName": "[toLower(format('{0}acr{1}', parameters('baseName'), variables('uniqueSuffix')))]",
    "acaEnvName": "[format('{0}-env-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "containerAppName": "[format('{0}-api', parameters('baseName'))]",
    "swaName": "[format('{0}-web-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "appInsightsName": "[format('{0}-insights-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "logAnalyticsName": "[format('{0}-logs-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "aiServicesName": "[format('{0}-ai-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "aiProjectName": "[format('{0}-project', parameters('baseName'))]",
    "bingSearchName": "[format('{0}-bing-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "docIntelligenceName": "[format('{0}-di-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "blobContainerName": "fd-rates",
    "appServicePlanName": "[format('{0}-plan-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "webAppName": "[format('{0}-web-app-{1}', parameters('baseName'), variables('uniqueSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "publicNetworkAccess": "Enabled",
        "networkAcls": {
          "copy": [
            {
              "name": "ipRules",
              "count": "[length(parameters('allowedClientIpAddresses'))]",
              "input": {
                "value": "[parameters('allowedClientIpAddresses')[copyIndex('ipRules')]]",
                "action": "Allow"
              }
            }
          ],
          "bypass": "AzureServices",
          "defaultAction": "[if(empty(parameters('allowedClientIpAddresses')), 'Allow', 'Deny')]",
          "virtualNetworkRules": []
        },
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageAccountName'), 'default')]",
