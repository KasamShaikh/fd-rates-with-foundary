{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/static/*",
            "/*.{css,js,png,jpg,jpeg,svg,ico,json}"
        ]
    },
    "responseOverrides": {
        "404": {
            "rewrite": "/index.html",
            "statusCode": 200
        }
    }
}